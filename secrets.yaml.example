# This is an example secrets file. Copy this to secrets.yaml and fill in your values.
# DO NOT commit secrets.yaml to version control!

# Wi-Fi credentials
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# OTA update password
display_ota: "YourOTAPassword"

# Security PIN code for alarm panel
security_pin_code: "1234"
